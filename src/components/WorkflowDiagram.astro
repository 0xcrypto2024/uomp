---
export interface Props {
  lang?: 'zh' | 'en';
}

const { lang = 'zh' } = Astro.props;

const labels = {
  zh: {
    title: 'UOMP 工作流程',
    discover: '发现 Agent',
    marketplace: 'Agent 市场 / ERC8004 Registry',
    manifest: 'uom.json 声明',
    authorize: '连接并授权',
    token: 'Capability Token',
    access: '访问记忆',
    guard: 'Memory Guard',
    store: 'Memory Store',
    revoke: '断开 / 撤销',
    expired: 'Token 失效',
  },
  en: {
    title: 'UOMP Workflow',
    discover: 'Discover Agent',
    marketplace: 'Agent Marketplace / ERC8004 Registry',
    manifest: 'uom.json Manifest',
    authorize: 'Connect & Authorize',
    token: 'Capability Token',
    access: 'Access Memory',
    guard: 'Memory Guard',
    store: 'Memory Store',
    revoke: 'Disconnect / Revoke',
    expired: 'Token Invalidated',
  },
};

const t = labels[lang];
---

<div class="workflow-diagram">
  <h3>{t.title}</h3>
  <svg viewBox="0 0 800 520" xmlns="http://www.w3.org/2000/svg" role="img" aria-label={t.title}>
    <defs>
      <marker id="arrowhead" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
        <polygon points="0 0, 10 3.5, 0 7" fill="#22d3ee" />
      </marker>
      <linearGradient id="boxGradient" x1="0%" y1="0%" x2="100%" y2="100%">
        <stop offset="0%" style="stop-color:#12121a;stop-opacity:1" />
        <stop offset="100%" style="stop-color:#1a1a24;stop-opacity:1" />
      </linearGradient>
    </defs>

    <!-- Marketplace -->
    <rect x="280" y="20" width="240" height="60" rx="8" fill="url(#boxGradient)" stroke="#2a2a3a" stroke-width="2" />
    <text x="400" y="45" text-anchor="middle" fill="#e4e4e7" font-size="14" font-weight="600">{t.discover}</text>
    <text x="400" y="65" text-anchor="middle" fill="#a1a1aa" font-size="11">{t.marketplace}</text>

    <!-- Arrow down -->
    <line x1="400" y1="80" x2="400" y2="110" stroke="#22d3ee" stroke-width="2" marker-end="url(#arrowhead)" />

    <!-- uom.json -->
    <rect x="280" y="120" width="240" height="60" rx="8" fill="url(#boxGradient)" stroke="#22d3ee" stroke-width="2" />
    <text x="400" y="145" text-anchor="middle" fill="#e4e4e7" font-size="14" font-weight="600">{t.manifest}</text>
    <text x="400" y="165" text-anchor="middle" fill="#a1a1aa" font-size="11">id, scopes, identity</text>

    <!-- Arrow down -->
    <line x1="400" y1="180" x2="400" y2="210" stroke="#22d3ee" stroke-width="2" marker-end="url(#arrowhead)" />

    <!-- User Authorizes -->
    <rect x="280" y="220" width="240" height="60" rx="8" fill="url(#boxGradient)" stroke="#2a2a3a" stroke-width="2" />
    <text x="400" y="245" text-anchor="middle" fill="#e4e4e7" font-size="14" font-weight="600">{t.authorize}</text>
    <text x="400" y="265" text-anchor="middle" fill="#a1a1aa" font-size="11">user confirms scope</text>

    <!-- Arrow to token -->
    <line x1="520" y1="250" x2="620" y2="250" stroke="#22d3ee" stroke-width="2" marker-end="url(#arrowhead)" />

    <!-- Token -->
    <rect x="630" y="220" width="150" height="60" rx="8" fill="url(#boxGradient)" stroke="#f87171" stroke-width="2" />
    <text x="705" y="245" text-anchor="middle" fill="#e4e4e7" font-size="13" font-weight="600">{t.token}</text>
    <text x="705" y="265" text-anchor="middle" fill="#a1a1aa" font-size="10">short-lived JWT</text>

    <!-- Arrow down from token -->
    <line x1="705" y1="280" x2="705" y2="340" stroke="#f87171" stroke-width="2" marker-end="url(#arrowhead)" />

    <!-- Arrow down from authorize -->
    <line x1="400" y1="280" x2="400" y2="340" stroke="#22d3ee" stroke-width="2" marker-end="url(#arrowhead)" />

    <!-- Agent -->
    <rect x="80" y="350" width="160" height="60" rx="8" fill="url(#boxGradient)" stroke="#2a2a3a" stroke-width="2" />
    <text x="160" y="375" text-anchor="middle" fill="#e4e4e7" font-size="14" font-weight="600">Agent</text>
    <text x="160" y="395" text-anchor="middle" fill="#a1a1aa" font-size="11">runs with token</text>

    <!-- Arrow right -->
    <line x1="240" y1="380" x2="320" y2="380" stroke="#22d3ee" stroke-width="2" marker-end="url(#arrowhead)" />

    <!-- Memory Guard -->
    <rect x="320" y="350" width="200" height="60" rx="8" fill="url(#boxGradient)" stroke="#22d3ee" stroke-width="2" />
    <text x="420" y="375" text-anchor="middle" fill="#e4e4e7" font-size="14" font-weight="600">{t.guard}</text>
    <text x="420" y="395" text-anchor="middle" fill="#a1a1aa" font-size="11">validate & filter</text>

    <!-- Arrow right -->
    <line x1="520" y1="380" x2="600" y2="380" stroke="#22d3ee" stroke-width="2" marker-end="url(#arrowhead)" />

    <!-- Memory Store -->
    <rect x="600" y="350" width="160" height="60" rx="8" fill="url(#boxGradient)" stroke="#2a2a3a" stroke-width="2" />
    <text x="680" y="375" text-anchor="middle" fill="#e4e4e7" font-size="14" font-weight="600">{t.store}</text>
    <text x="680" y="395" text-anchor="middle" fill="#a1a1aa" font-size="11">user-owned data</text>

    <!-- Arrow down from guard to revoke -->
    <line x1="420" y1="410" x2="420" y2="450" stroke="#22d3ee" stroke-width="2" marker-end="url(#arrowhead)" />

    <!-- Revoke -->
    <rect x="300" y="460" width="240" height="50" rx="8" fill="url(#boxGradient)" stroke="#f87171" stroke-width="2" />
    <text x="420" y="482" text-anchor="middle" fill="#e4e4e7" font-size="13" font-weight="600">{t.revoke}</text>
    <text x="420" y="498" text-anchor="middle" fill="#a1a1aa" font-size="10">{t.expired}</text>
  </svg>
</div>

<style>
  .workflow-diagram {
    margin: 2rem 0;
    padding: 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
  }

  .workflow-diagram h3 {
    margin-top: 0;
    margin-bottom: 1rem;
    text-align: center;
    color: var(--color-primary);
  }

  .workflow-diagram svg {
    width: 100%;
    height: auto;
    max-width: 800px;
    display: block;
    margin: 0 auto;
  }

  .workflow-diagram text {
    font-family: system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }
</style>
