---
import { baseUrl } from '../utils/base.ts';

export interface Props {
  title: string;
  description?: string;
  lang?: 'zh' | 'en';
  switchHref?: string;
}

const { title, description = 'User-Owned Memory Protocol - 用户主权型 Agent 记忆授权协议', lang = 'zh', switchHref } = Astro.props;

const nav = {
  zh: {
    home: '首页',
    spec: '规范',
    design: '实现',
    tutorial: '教程',
    example: '示例',
    roadmap: '路线图',
    github: 'GitHub',
    switch: 'EN',
    brand: 'UOMP',
    brandTagline: '用户主权型 Agent 记忆授权协议',
    footerCols: {
      protocol: { title: '协议', links: [{ t: '规范', h: `${baseUrl}spec/` }, { t: '实现设计', h: `${baseUrl}design/` }, { t: '教程', h: `${baseUrl}tutorial/` }, { t: '示例', h: `${baseUrl}example/` }, { t: '路线图', h: `${baseUrl}roadmap/` }, { t: 'Dashboard', h: `${baseUrl}dashboard/` }] },
      community: { title: '社区', links: [{ t: 'GitHub', h: 'https://github.com/0xaicrypto/uomp-core' }, { t: 'Discussions', h: 'https://github.com/0xaicrypto/uomp-core/discussions' }] },
    },
    footerBtm: '© UOMP 贡献者 · 开放协议草案',
  },
  en: {
    home: 'Home',
    spec: 'Spec',
    design: 'Implementation',
    tutorial: 'Tutorial',
    example: 'Example',
    roadmap: 'Roadmap',
    github: 'GitHub',
    switch: '中文',
    brand: 'UOMP',
    brandTagline: 'User-sovereign Agent memory authorization protocol',
    footerCols: {
      protocol: { title: 'Protocol', links: [{ t: 'Spec', h: `${baseUrl}en/spec/` }, { t: 'Implementation', h: `${baseUrl}en/design/` }, { t: 'Tutorial', h: `${baseUrl}en/tutorial/` }, { t: 'Example', h: `${baseUrl}en/example/` }, { t: 'Roadmap', h: `${baseUrl}en/roadmap/` }, { t: 'Dashboard', h: `${baseUrl}dashboard/` }] },
      community: { title: 'Community', links: [{ t: 'GitHub', h: 'https://github.com/0xaicrypto/uomp-core' }, { t: 'Discussions', h: 'https://github.com/0xaicrypto/uomp-core/discussions' }] },
    },
    footerBtm: '© UOMP contributors · Open protocol draft',
  },
};

const t = nav[lang];
const homeHref = lang === 'zh' ? baseUrl : `${baseUrl}en/`;
const specHref = lang === 'zh' ? `${baseUrl}spec/` : `${baseUrl}en/spec/`;
const designHref = lang === 'zh' ? `${baseUrl}design/` : `${baseUrl}en/design/`;
const tutorialHref = lang === 'zh' ? `${baseUrl}tutorial/` : `${baseUrl}en/tutorial/`;
const exampleHref = lang === 'zh' ? `${baseUrl}example/` : `${baseUrl}en/example/`;
const roadmapHref = lang === 'zh' ? `${baseUrl}roadmap/` : `${baseUrl}en/roadmap/`;
const resolvedSwitchHref = switchHref ?? (lang === 'zh' ? `${baseUrl}en/` : baseUrl);

const pathname = Astro.url.pathname;
const isHome = pathname === baseUrl || pathname === `${baseUrl}en/` || pathname === `${baseUrl}index.html`;
const isSpec = pathname.startsWith(`${baseUrl}spec/`) || pathname.startsWith(`${baseUrl}en/spec/`);
const isDesign = pathname.startsWith(`${baseUrl}design/`) || pathname.startsWith(`${baseUrl}en/design/`);
const isTutorial = pathname.startsWith(`${baseUrl}tutorial/`) || pathname.startsWith(`${baseUrl}en/tutorial/`);
const isExample = pathname.startsWith(`${baseUrl}example/`) || pathname.startsWith(`${baseUrl}en/example/`);
const isRoadmap = pathname.startsWith(`${baseUrl}roadmap/`) || pathname.startsWith(`${baseUrl}en/roadmap/`);
---

<!DOCTYPE html>
<html lang={lang === 'zh' ? 'zh-CN' : 'en'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={Astro.url.href} />
    <meta property="og:site_name" content="UOMP" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />

    <!-- hreflang -->
    <link rel="canonical" href={Astro.url.href.replace(/\/$/, '') + '/'} />
    {lang === 'zh' ? (
      <link rel="alternate" hreflang="en" href={switchHref || `${baseUrl}en/`} />
    ) : (
      <link rel="alternate" hreflang="zh-CN" href={switchHref || baseUrl} />
    )}

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,600;0,700;1,400&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href={`${baseUrl}styles/global.css`} />
  </head>
  <body>
    <div class="nav-outer">
      <nav>
        <a href={homeHref} class="nav-logo" aria-label={t.brand}>
          <div class="nav-lm">
            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2L2 7l10 5 10-5-10-5z"/>
              <path d="M2 17l10 5 10-5"/>
              <path d="M2 12l10 5 10-5"/>
            </svg>
          </div>
          <span>{t.brand}</span>
        </a>
        <ul class="nav-links">
          <li><a href={homeHref} class={isHome ? 'active' : ''}>{t.home}</a></li>
          <li><a href={specHref} class={isSpec ? 'active' : ''}>{t.spec}</a></li>
          <li><a href={designHref} class={isDesign ? 'active' : ''}>{t.design}</a></li>
          <li><a href={tutorialHref} class={isTutorial ? 'active' : ''}>{t.tutorial}</a></li>
          <li><a href={exampleHref} class={isExample ? 'active' : ''}>{t.example}</a></li>
          <li><a href={roadmapHref} class={isRoadmap ? 'active' : ''}>{t.roadmap}</a></li>
        </ul>
        <div class="nav-r">
          <button class="nav-hamburger" id="hamburger" aria-label="Menu" style="display:none">
            <span></span>
          </button>
          <a href={resolvedSwitchHref} class="btn-ng">{t.switch}</a>
          <a href="https://github.com/0xaicrypto/uomp-core" target="_blank" rel="noopener" class="btn-np">{t.github}</a>
        </div>
      </nav>
    </div>
    <main>
      <slot />
    </main>
    <footer>
      <div class="footer-top">
        <div class="footer-brand">
          <a href={homeHref} class="footer-logo">
            <div class="footer-lm">
              <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M12 2L2 7l10 5 10-5-10-5z"/>
                <path d="M2 17l10 5 10-5"/>
                <path d="M2 12l10 5 10-5"/>
              </svg>
            </div>
            <span>{t.brand}</span>
          </a>
          <p>{t.brandTagline}</p>
        </div>
        <div class="footer-col">
          <h4>{t.footerCols.protocol.title}</h4>
          <ul>
            {t.footerCols.protocol.links.map(l => (
              <li><a href={l.h} target={l.h.startsWith('http') ? '_blank' : undefined} rel={l.h.startsWith('http') ? 'noopener' : undefined}>{l.t}</a></li>
            ))}
          </ul>
        </div>
        <div class="footer-col">
          <h4>{t.footerCols.community.title}</h4>
          <ul>
            {t.footerCols.community.links.map(l => (
              <li><a href={l.h} target="_blank" rel="noopener">{l.t}</a></li>
            ))}
          </ul>
        </div>
      </div>
      <div class="footer-btm">
        <span>{t.footerBtm}</span>
      </div>
    </footer>
    <script>
      const btn = document.getElementById('hamburger');
      const links = document.querySelector('.nav-links');
      if (btn && links) {
        if (window.innerWidth <= 768) btn.style.display = 'flex';
        window.addEventListener('resize', () => {
          btn.style.display = window.innerWidth <= 768 ? 'flex' : 'none';
          if (window.innerWidth > 768) links.classList.remove('open');
        });
        btn.addEventListener('click', () => links.classList.toggle('open'));
      }
    </script>
  </body>
</html>
