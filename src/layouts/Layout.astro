---
import { baseUrl } from '../utils/base.ts';

export interface Props {
  title: string;
  description?: string;
  lang?: 'zh' | 'en';
  switchHref?: string;
}

const { title, description = 'User-Owned Memory Protocol - 用户主权型 Agent 记忆授权协议', lang = 'zh', switchHref } = Astro.props;

const nav = {
  zh: {
    home: '首页',
    spec: '规范',
    design: '实现',
    roadmap: '路线图',
    github: 'GitHub',
    switch: 'EN',
    footer: 'UOMP 是一个开放协议草案。欢迎通过 <a href="https://github.com/0xaicrypto/uomp">GitHub</a> 参与讨论。',
  },
  en: {
    home: 'Home',
    spec: 'Spec',
    design: 'Implementation',
    roadmap: 'Roadmap',
    github: 'GitHub',
    switch: '中文',
    footer: 'UOMP is an open protocol draft. Join the discussion on <a href="https://github.com/0xaicrypto/uomp">GitHub</a>.',
  },
};

const t = nav[lang];
const homeHref = lang === 'zh' ? baseUrl : `${baseUrl}en/`;
const specHref = lang === 'zh' ? `${baseUrl}spec/` : `${baseUrl}en/spec/`;
const designHref = lang === 'zh' ? `${baseUrl}design/` : `${baseUrl}en/design/`;
const roadmapHref = lang === 'zh' ? `${baseUrl}roadmap/` : `${baseUrl}en/roadmap/`;
const resolvedSwitchHref = switchHref ?? (lang === 'zh' ? `${baseUrl}en/` : baseUrl);

const pathname = Astro.url.pathname;
const isHome = pathname === baseUrl || pathname === `${baseUrl}en/` || pathname === `${baseUrl}index.html`;
const isSpec = pathname.startsWith(`${baseUrl}spec/`) || pathname.startsWith(`${baseUrl}en/spec/`);
const isDesign = pathname.startsWith(`${baseUrl}design/`) || pathname.startsWith(`${baseUrl}en/design/`);
const isRoadmap = pathname.startsWith(`${baseUrl}roadmap/`) || pathname.startsWith(`${baseUrl}en/roadmap/`);
---

<!DOCTYPE html>
<html lang={lang === 'zh' ? 'zh-CN' : 'en'}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="stylesheet" href={`${baseUrl}styles/global.css`} />
  </head>
  <body>
    <header>
      <div class="container">
        <a href={homeHref} class="logo">
          <span>UOMP</span>
        </a>
        <nav>
          <a href={homeHref} class={isHome ? 'active' : ''}>{t.home}</a>
          <a href={specHref} class={isSpec ? 'active' : ''}>{t.spec}</a>
          <a href={designHref} class={isDesign ? 'active' : ''}>{t.design}</a>
          <a href={roadmapHref} class={isRoadmap ? 'active' : ''}>{t.roadmap}</a>
          <a href="https://github.com/0xaicrypto/uomp" target="_blank" rel="noopener">{t.github}</a>
          <a href={resolvedSwitchHref} class="lang-switch">{t.switch}</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <div class="container" set:html={t.footer} />
    </footer>
  </body>
</html>
