---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - UOMP" description="Page not found">
  <section>
    <div class="container" style="text-align:center;padding:4rem 1rem;">
      <h1 style="font-size:4rem;margin:0;color:#D1D5DB;">404</h1>
      <p style="font-size:1.2rem;margin:1rem 0 2rem;color:#9CA3AF;">Page not found · 页面不存在</p>
      <div class="hero-btns" style="justify-content:center;">
        <a href="/" class="btn-h1">Home · 首页 →</a>
        <a href="/en/" class="btn-h2">English</a>
      </div>
    </div>
  </section>
</Layout>
