---
import Layout from '../../layouts/Layout.astro';
import { baseUrl } from '../../utils/base.ts';
---

<Layout
  title="Examples - UOMP"
  description="UOMP examples: Browser Dashboard and CLI Stock Analyst Agent"
  lang="en"
  switchHref={`${baseUrl}example/`}
>
  <section>
    <div class="container">
      <div class="sec-eyebrow">
        <div class="sec-num">Examples</div>
        <span class="sec-tag">Two entry points, one protocol</span>
      </div>
      <h1>UOMP Examples</h1>
      <p>
        UOMP offers two ways to use it, both backed by the same SDK and protocol. Pick what fits you.
      </p>

      <div style="display:flex;gap:2rem;flex-wrap:wrap;margin-top:2rem">
        <div class="card" style="flex:1;min-width:300px;border:2px solid var(--purple)">
          <div class="card-label" style="color:var(--purple);font-size:1.1rem;margin-bottom:.5rem">🖥️ Browser Dashboard</div>
          <p style="color:var(--mid);margin-bottom:1rem">Zero install. Connect wallet + Dropbox to manage your portfolio and run analysis directly in the browser.</p>
          <ul style="color:var(--mid);font-size:.85rem;list-style:none;padding:0;margin-bottom:1rem">
            <li style="padding:.2rem 0">✅ No CLI, no server required</li>
            <li style="padding:.2rem 0">✅ MetaMask / Argent X wallet auth</li>
            <li style="padding:.2rem 0">✅ Dropbox encrypted storage</li>
            <li style="padding:.2rem 0">✅ Agent analysis (P&L, Sharpe, Beta, signals)</li>
            <li style="padding:.2rem 0">✅ CSV import + inline editing</li>
          </ul>
          <a href={`${baseUrl}dashboard/`} style="display:inline-block;padding:.7rem 1.5rem;background:var(--purple);border-radius:6px;color:#fff;text-decoration:none;font-weight:600;font-size:.9rem">Open Dashboard →</a>
        </div>

        <div class="card" style="flex:1;min-width:300px">
          <div class="card-label" style="font-size:1.1rem;margin-bottom:.5rem">⌨️ CLI Stock Analyst</div>
          <p style="color:var(--mid);margin-bottom:1rem">For developers / AI Agents. Use CLI + SDK, access data remotely via Gateway or locally.</p>
          <ul style="color:var(--mid);font-size:.85rem;list-style:none;padding:0;margin-bottom:1rem">
            <li style="padding:.2rem 0">✅ <code>@uomp/sdk</code> TypeScript SDK</li>
            <li style="padding:.2rem 0">✅ Gateway + Cloudflare Tunnel remote access</li>
            <li style="padding:.2rem 0">✅ Multi-dim analysis: Sharpe, Beta, MACD, RSI</li>
            <li style="padding:.2rem 0">✅ Capability Token authorization</li>
            <li style="padding:.2rem 0">✅ Digital Ocean deployment ready</li>
          </ul>
          <a href="https://github.com/0xaicrypto/uomp-core/tree/main/examples/stock-analyst" target="_blank" rel="noopener" style="display:inline-block;padding:.7rem 1.5rem;background:var(--blu);border-radius:6px;color:#fff;text-decoration:none;font-weight:600;font-size:.9rem">GitHub →</a>
        </div>
      </div>

      <h2 style="margin-top:3rem">How They Relate</h2>
      <p style="color:var(--mid)">
        The Browser Dashboard and CLI Agent are two entry points to the <strong>same UOMP implementation</strong>.
        They share <code>@uomp/sdk</code>, <code>@uomp/core</code>, the Token system, Guard enforcement, and audit logging.
        The only difference is the UI: one is a browser (wallet + Dropbox), the other is a terminal (Token + SDK).
      </p>

      <div class="hero-btns" style="margin-top: 2.5rem;">
        <a href={`${baseUrl}en/tutorial/`} class="btn-h1">SDK Tutorial →</a>
        <a href={`${baseUrl}en/design/`} class="btn-h1">Implementation →</a>
        <a href="https://github.com/0xaicrypto/uomp-core" target="_blank" rel="noopener" class="btn-h2">GitHub</a>
      </div>
    </div>
  </section>
</Layout>
