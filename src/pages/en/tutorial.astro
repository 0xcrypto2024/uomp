---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import { baseUrl } from '../../utils/base.ts';

const tutorials = await getCollection('tutorial');
const t = tutorials.find(t => t.slug === 'tutorial.en');
const { Content } = t ? await t.render() : { Content: null };
---

<Layout
  title="SDK/CLI Tutorial - UOMP"
  description="Complete guide from zero to deployed"
  lang="en"
  switchHref={`${baseUrl}tutorial/`}
>
  <section>
    <div class="container">
      <div class="sec-eyebrow">
        <div class="sec-num">Tutorial</div>
        <span class="sec-tag">From zero to deployed</span>
      </div>
      {Content && <Content />}
      <div class="hero-btns" style="margin-top: 2.5rem;">
        <a href={`${baseUrl}en/spec/`} class="btn-h1">Specification →</a>
        <a href={`${baseUrl}en/design/`} class="btn-h1">Implementation →</a>
        <a href="https://github.com/0xaicrypto/uomp-core" target="_blank" rel="noopener" class="btn-h2">GitHub</a>
      </div>
    </div>
  </section>
</Layout>
