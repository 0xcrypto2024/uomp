---
import Layout from '../layouts/Layout.astro';
import { baseUrl } from '../utils/base.ts';
---

<Layout title="示例 - UOMP" description="UOMP 示例：浏览器 Dashboard 和 CLI 股票分析 Agent" switchHref={`${baseUrl}en/example/`}>
  <section>
    <div class="container">
      <div class="sec-eyebrow">
        <div class="sec-num">示例</div>
        <span class="sec-tag">两个入口，同一套协议</span>
      </div>
      <h1>UOMP 示例</h1>
      <p>
        UOMP 提供两种使用方式，底层共享同一个 SDK 和协议。选择适合你的入口。
      </p>

      <div style="display:flex;gap:2rem;flex-wrap:wrap;margin-top:2rem">
        <!-- Browser Dashboard -->
        <div class="card" style="flex:1;min-width:300px;border:2px solid var(--purple)">
          <div class="card-label" style="color:var(--purple);font-size:1.1rem;margin-bottom:.5rem">🖥️ 浏览器 Dashboard</div>
          <p style="color:var(--mid);margin-bottom:1rem">零安装。连接钱包 + Dropbox，直接在浏览器中管理投资组合并运行分析。</p>
          <ul style="color:var(--mid);font-size:.85rem;list-style:none;padding:0;margin-bottom:1rem">
            <li style="padding:.2rem 0">✅ 无需 CLI，无需服务器</li>
            <li style="padding:.2rem 0">✅ MetaMask / Argent X 钱包签名</li>
            <li style="padding:.2rem 0">✅ Dropbox 加密存储</li>
            <li style="padding:.2rem 0">✅ Agent 分析（P&L、Sharpe、Beta、信号）</li>
            <li style="padding:.2rem 0">✅ CSV 导入 + 在线编辑</li>
          </ul>
          <a href={`${baseUrl}dashboard/`} style="display:inline-block;padding:.7rem 1.5rem;background:var(--purple);border-radius:6px;color:#fff;text-decoration:none;font-weight:600;font-size:.9rem">打开 Dashboard →</a>
        </div>

        <!-- CLI Stock Analyst -->
        <div class="card" style="flex:1;min-width:300px">
          <div class="card-label" style="font-size:1.1rem;margin-bottom:.5rem">⌨️ CLI 股票分析 Agent</div>
          <p style="color:var(--mid);margin-bottom:1rem">开发者/AI Agent 使用 CLI + SDK，通过 Gateway 远程访问数据或本地运行。</p>
          <ul style="color:var(--mid);font-size:.85rem;list-style:none;padding:0;margin-bottom:1rem">
            <li style="padding:.2rem 0">✅ <code>@uomp/sdk</code> TypeScript SDK</li>
            <li style="padding:.2rem 0">✅ Gateway + Cloudflare Tunnel 远程访问</li>
            <li style="padding:.2rem 0">✅ 多维度分析：Sharpe、Beta、MACD、RSI</li>
            <li style="padding:.2rem 0">✅ Capability Token 授权</li>
            <li style="padding:.2rem 0">✅ Digital Ocean 部署就绪</li>
          </ul>
          <a href="https://github.com/0xaicrypto/uomp-core/tree/main/examples/stock-analyst" target="_blank" rel="noopener" style="display:inline-block;padding:.7rem 1.5rem;background:var(--blu);border-radius:6px;color:#fff;text-decoration:none;font-weight:600;font-size:.9rem">GitHub →</a>
        </div>
      </div>

      <h2 style="margin-top:3rem">两者关系的简短说明</h2>
      <p style="color:var(--mid)">
        浏览器 Dashboard 和 CLI Agent 是 UOMP 协议的<strong>同一个实现</strong>的两种入口形式。
        它们共享 <code>@uomp/sdk</code>、<code>@uomp/core</code>、Token 体系、Guard 鉴权和审计日志。
        区别只在于用户界面：一个是浏览器（钱包 + Dropbox），一个是命令行（Token + SDK）。
      </p>

      <div class="hero-btns" style="margin-top: 2.5rem;">
        <a href={`${baseUrl}tutorial/`} class="btn-h1">SDK 教程 →</a>
        <a href={`${baseUrl}design/`} class="btn-h1">实现设计 →</a>
        <a href="https://github.com/0xaicrypto/uomp-core" target="_blank" rel="noopener" class="btn-h2">GitHub</a>
      </div>
    </div>
  </section>
</Layout>
