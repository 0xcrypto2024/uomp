---
import Layout from '../layouts/Layout.astro';
import { baseUrl } from '../utils/base.ts';
---

<Layout title="路线图 - UOMP" description="UOMP 从协议草案到完整生态的发展规划与实现进度" switchHref={`${baseUrl}en/roadmap/`}>
  <section>
    <div class="container">
      <h1>路线图</h1>
      <p>UOMP 从协议草案到完整生态的发展规划。</p>

      <h2>Milestone 1：核心协议与参考实现（已完成）</h2>
      <ul class="roadmap-list">
        <li><span class="status status-done">已完成</span>发布 UOMP-Draft-00 规范草案</li>
        <li><span class="status status-done">已完成</span>基于 SQLite 的 Memory Store</li>
        <li><span class="status status-done">已完成</span>Auth Service HTTP API：Session 创建/授权/关闭/撤销</li>
        <li><span class="status status-done">已完成</span>Memory Guard HTTP API：只读访问，按 tag/key 过滤</li>
        <li><span class="status status-done">已完成</span>JWT Capability Token 签发与校验</li>
        <li><span class="status status-done">已完成</span>Token 黑名单持久化到 SQLite</li>
        <li><span class="status status-done">已完成</span><code>uom.json</code> Agent Manifest 解析</li>
        <li><span class="status status-done">已完成</span>ERC-8004 兼容 Registry 本地索引</li>
        <li><span class="status status-done">已完成</span>通用 CLI：`discover`/`connect`/`authorize`/`import`/`sessions`/`revoke`/`audit`</li>
        <li><span class="status status-done">已完成</span>股票分析 Agent 完整示例</li>
        <li><span class="status status-done">已完成</span>Remote Profile + Gateway 参考实现（mTLS + 远程 Capability Token 转发）</li>
        <li><span class="status status-done">已完成</span>聚合查询（`/v1/memory/aggregate`）+ 删除证明 API</li>
        <li><span class="status status-done">已完成</span>Token Claims：`allowed_fields`、`aggregation_only`、`task_bound`</li>
        <li><span class="status status-done">已完成</span>Agent Manifest `data_retention_policy`</li>
        <li><span class="status status-done">已完成</span>UOMP SDK Phase 1（`UompClient`：memory / aggregate / payload / session / audit / auth / identity）</li>
        <li><span class="status status-done">已完成</span>浏览器 Dashboard（uomp.org/dashboard/）：钱包认证 + Dropbox + Agent 分析</li>
        <li><span class="status status-done">已完成</span>Cloudflare Tunnel 集成（`uomp gateway start` 一键暴露公网）</li>
        <li><span class="status status-done">已完成</span>Store 抽象化（`IMemoryStore` 接口，SQLite + EncryptedObject）</li>
        <li><span class="status status-done">已完成</span>Cloud Relay（`apps/relay/`，CORS + 限流 + 公钥验签）</li>
        <li><span class="status status-done">已完成</span>钱包认证（MetaMask + Argent X，PBKDF2 密钥推导）</li>
        <li><span class="status status-done">已完成</span>UOMP SDK Phase 1（`UompClient`：memory / aggregate / payload / session / audit）</li>
        <li><span class="status status-done">已完成</span>股票分析 Agent v1.0（自服务 HTTP API + Digital Ocean 部署）</li>
        <li><span class="status status-done">已完成</span>Cloudflare Tunnel 集成（`uomp gateway start` 一键暴露公网）</li>
        <li><span class="status status-current">进行中</span>DID / GPG / X.509 身份验证（框架存在，验证强度增强）</li>
      </ul>

      <h2>Milestone 2：体验增强、写入与 GUI 集成</h2>
      <ul class="roadmap-list">
        <li><span class="status status-next">计划</span><code>uomp import</code> 字段映射、格式识别、预览</li>
        <li><span class="status status-next">计划</span><code>uomp dry-run</code> 模拟授权</li>
        <li><span class="status status-next">计划</span><code>uomp config</code> 用户配置</li>
        <li><span class="status status-next">计划</span>Agent 写入暂存区（Staging）机制</li>
        <li><span class="status status-next">计划</span><code>uom memory review</code> 用户审核命令</li>
        <li><span class="status status-done">已完成</span>图形化授权面板（浏览器 Dashboard）</li>
        <li><span class="status status-done">已完成</span>TypeScript SDK（`UompClient`、mTLS、聚合、Payload、删除证明）</li>
        <li><span class="status status-done">已完成</span>Memory Store 抽象化（SQLite / S3 / IPFS 可插拔）</li>
        <li><span class="status status-next">计划</span>审计日志可视化</li>
        <li><span class="status status-next">计划</span>Token 安全托管模式（反向代理）</li>
      </ul>

      <h2>Milestone 3：远程与高级能力</h2>
      <ul class="roadmap-list">
        <li><span class="status status-future">未来</span>语义检索（<code>query</code> 接口）</li>
        <li><span class="status status-future">未来</span>写入版本历史与回滚</li>
        <li><span class="status status-future">未来</span>策略模板（如"仅偏好"、"偏好+公开身份"）</li>
        <li><span class="status status-future">未来</span>授权与访问事件区块链锚定</li>
      </ul>
    </div>
    <div class="hero-btns" style="margin-top:2.5rem;">
      <a href={`${baseUrl}dashboard/`} class="btn-h1" style="background:#8B5CF6">打开 Dashboard →</a>
      <a href={`${baseUrl}tutorial/`} class="btn-h1">SDK 教程 →</a>
    </div>
  </section>
</Layout>
