---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { baseUrl } from '../utils/base.ts';

const tutorials = await getCollection('tutorial');
const t = tutorials.find(t => t.slug === 'tutorial');
const { Content } = t ? await t.render() : { Content: null };
---

<Layout title="SDK/CLI 教程 - UOMP" description="从零到部署的完整指南：安装、导入、授权、SDK、Gateway" switchHref={`${baseUrl}en/tutorial/`}>
  <section>
    <div class="container">
      <div class="sec-eyebrow">
        <div class="sec-num">教程</div>
        <span class="sec-tag">从零到部署的完整指南</span>
      </div>
      {Content && <Content />}
      <div class="hero-btns" style="margin-top: 2.5rem;">
        <a href={`${baseUrl}spec/`} class="btn-h1">协议规范 →</a>
        <a href={`${baseUrl}design/`} class="btn-h1">实现设计 →</a>
        <a href="https://github.com/0xaicrypto/uomp-core" target="_blank" rel="noopener" class="btn-h2">GitHub</a>
      </div>
    </div>
  </section>
</Layout>
